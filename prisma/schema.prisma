// Growth Metrics Dashboard - Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Metric {
  id        String   @id @default(uuid())
  name      String
  value     Float
  timestamp DateTime @default(now())
  unit      String   @default("Count") // Count | Percentage | Currency | Seconds
  createdAt DateTime @default(now())

  @@index([timestamp])
  @@index([name])
  @@index([createdAt])
}
